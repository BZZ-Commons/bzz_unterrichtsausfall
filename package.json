    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^17.0.7",
    "postcss": "^8.4.31",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.1.14",
